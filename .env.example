# ============================================================
# Social Kanban — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# Only FLASK_SECRET_KEY is required for basic local use.
# Everything else is optional and enables additional features.

# --- Required ---------------------------------------------------
FLASK_SECRET_KEY=change-me-to-a-random-string

# --- Dashboard Auth (optional) ----------------------------------
# Set a password to require login. Leave unset for open access.
# DASHBOARD_PASSWORD=

# --- Database (optional) ----------------------------------------
# Leave unset to use local SQLite (data/social_kanban.db).
# Set to a PostgreSQL URL for production.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Branding (optional) ----------------------------------------
# Override config/settings.yaml defaults via env vars.
# BRAND_NAME=Social Kanban
# BRAND_HANDLE=socialkanban
# BRAND_TAGLINE=Plan. Create. Post.
# BRAND_DOMAIN=
# BRAND_HASHTAGS=#SocialKanban #ContentCreator

# --- AI Content Generation (optional) ---------------------------
# Anthropic — used for post formatting and stoic card generation
# ANTHROPIC_API_KEY=

# Groq — used for quote extraction from documents
# GROQ_API_KEY=

# --- Social Media APIs (optional) -------------------------------
# X/Twitter
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
# TWITTER_BEARER_TOKEN=

# Facebook Page
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_TOKEN=

# Instagram (via Facebook Graph API)
# INSTAGRAM_ACCOUNT_ID=

# --- Image Hosting (optional) -----------------------------------
# Cloudinary — for uploading generated card images
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Profile (for social cards) ----------------------------------
# PROFILE_PICTURE_URL=
# PROFILE_NAME=
# PROFILE_HANDLE=
